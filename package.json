{
  "name": "hunter-agent",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "css:build": "tailwindcss -i ./app/static/tailwind.css -o ./app/static/styles.css --minify",
    "css:watch": "tailwindcss -i ./app/static/tailwind.css -o ./app/static/styles.css --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.17",
    "daisyui": "^5.5.20",
    "prettier": "^3.8.3",
    "prettier-plugin-jinja-template": "^2.2.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.1.17"
  }
}
