filters:
  and:
    - file.inFolder("quests")
properties:
  file.name:
    displayName: Quest
  id:
    displayName: ID
  title:
    displayName: Title
  status:
    displayName: Status
  points:
    displayName: Proximity
  area:
    displayName: Area
  order:
    displayName: Order
views:
  - type: table
    name: Quests
    order:
      - file.name
      - id
      - title
      - status
      - points
      - area
      - order
    sort:
      - property: order
        direction: ASC
      - property: status
        direction: ASC
  - type: table
    name: By Status
    groupBy:
      property: status
      direction: ASC
    order:
      - file.name
      - id
      - title
      - points
      - area
      - order
    sort:
      - property: order
        direction: ASC
